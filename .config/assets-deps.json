  "workflows": {
    "adding_global_css": {
      "description": "How to add a new global CSS file loaded on all pages",
      "steps": [
        "1. Create CSS file in public_html/resources/css/",
        "2. Add to head.php between line 149 and 152",
        "3. Use <?= RES_ROOT ?>/css/filename<?= $assetSuffix ?>.css",
        "4. Run build-all.ps1 to create minified version",
        "5. Test on localhost:8002 (dev) and production (minified)"
      ]
    },
    "adding_global_js": {
      "description": "How to add a new global JavaScript file loaded on all pages",
      "steps": [
        "1. Create JS file in public_html/resources/js/",
        "2. Add to footer.php between line 125 and 132",
        "3. Use <?= RES_ROOT ?>/js/filename<?= $assetSuffix ?>.js",
        "4. Run build-all.ps1 to create minified version",
        "5. Test on localhost:8002 (dev) and production (minified)"
      ]
    },
    "adding_page_css": {
      "description": "How to add CSS for a specific page",
      "steps": [
        "1. Create theme CSS file in public_html/resources/css/",
        "2. In the page PHP, before including head.php:",
        "3. Set $customCSS = [RES_ROOT . '/css/your-theme.min.css'];",
        "4. OR: $customCSS = ['resources/css/your-theme.min.css']; (relative)",
        "5. Run build-all.ps1 to create minified version",
        "6. head.php will automatically inject it (lines 164-169)"
      ],
      "examples": [
        "gamedev.php: $customCSS = [RES_ROOT . '/css/gamedev-theme.min.css'];",
        "diy.php: $customCSS = ['resources/css/diy-theme.min.css'];"
      ]
    },
    "adding_page_js": {
      "description": "How to add JavaScript for a specific page",
      "steps": [
        "1. Create JS file in public_html/resources/js/",
        "2. In the page PHP, before including footer.php:",
        "3. Set $pageScripts = [RES_ROOT . '/js/your-script.min.js'];",
        "4. OR: $pageScripts = ['resources/js/your-script.min.js']; (relative)",
        "5. For multiple scripts: $pageScripts = ['script1.js', 'script2.js'];",
        "6. Run build-all.ps1 to create minified version",
        "7. footer.php will automatically inject them (lines 140-151)"
      ],
      "examples": [
        "youtube.php loads tag-system.js and youtube-grid.js",
        "diy.php loads tag-system.js and diy-playlists.js"
      ]
    },
    "minification": {
      "description": "How CSS/JS minification works",
      "steps": [
        "1. Run scripts/build-all.ps1 from jenninexus root",
        "2. Script calls scripts/minify-assets.ps1",
        "3. Finds all .css files without .min.css",
        "4. Finds all .js files without .min.js",
        "5. Creates .min.css and .min.js versions (strip whitespace, comments)",
        "6. Production environment auto-loads .min versions via $assetSuffix"
      ],
      "script_path": "scripts/minify-assets.ps1",
      "triggered_by": "build-all.ps1 (main build pipeline)"
    },
    "environment_detection": {
      "description": "How dev vs production asset loading works",
      "logic": [
        "head.php lines 4-9: Checks $_SERVER['REMOTE_ADDR'] and $_SERVER['HTTP_HOST']",
        "If localhost/127.0.0.1/port 8002: $assetSuffix = '' (load .css/.js)",
        "If production (jenninexus.com): $assetSuffix = '.min' (load .min.css/.min.js)",
        "All asset tags use <?= $assetSuffix ?> to auto-switch",
        "window.RES_ROOT exposed to JavaScript for dynamic resource loading"
      ],
      "dev_urls": ["http://localhost:8002", "http://127.0.0.1:8002"],
      "prod_url": "https://jenninexus.com"
    }
  },
  "critical_rules": [
    "ALWAYS use <?= RES_ROOT ?> for resource paths in PHP (NOT hardcoded /resources)",
    "ALWAYS use <?= $assetSuffix ?> for .css/.js extensions (enables dev/prod switching)",
    "NEVER use <?= RES_ROOT ?> inside JavaScript template literals (use '/resources' or window.RES_ROOT)",
    "Set $customCSS array BEFORE including head.php for page-specific CSS",
    "Set $pageScripts array BEFORE including footer.php for page-specific JS",
    "Run build-all.ps1 after modifying any CSS/JS to create minified versions",
    "Test on localhost:8002 (dev mode) BEFORE deploying to production",
    "Global CSS/JS goes in head.php/footer.php, page-specific uses $customCSS/$pageScripts",
    "Font Awesome 6.7.2 preferred over Bootstrap Icons (legacy)",
    "All themes extend Bootstrap 5.3.8 custom properties (main.css)"
  ],
  "troubleshooting": {
    "css_not_loading": {
      "symptoms": "Styles missing, theme not applied",
      "solutions": [
        "Check $customCSS array is set BEFORE head.php include",
        "Verify RES_ROOT path is correct (starts with / or uses RES_ROOT constant)",
        "Run build-all.ps1 to ensure .min.css exists",
        "Check browser console for 404 errors",
        "Clear browser cache (Ctrl+Shift+R)"
      ]
    },
    "js_not_loading": {
      "symptoms": "Interactive features broken, console errors",
      "solutions": [
        "Check $pageScripts array is set BEFORE footer.php include",
        "Verify script path is correct (use RES_ROOT constant)",
        "Run build-all.ps1 to ensure .min.js exists",
        "Check browser console for 404 or syntax errors",
        "Ensure dependencies loaded first (js-yaml before youtube-grid.js)"
      ]
    },
    "wrong_assets_loading": {
      "symptoms": "Loading .min files in dev or .css files in production",
      "solutions": [
        "Check head.php lines 4-9 environment detection logic",
        "Verify localhost is in allowed list (127.0.0.1, localhost, :8002)",
        "Check $assetSuffix variable is set correctly",
        "Test URL matches dev_urls in environment_detection workflow"
      ]
    },
    "minified_files_missing": {
      "symptoms": "404 errors for .min.css or .min.js in production",
      "solutions": [
        "Run build-all.ps1 to generate all minified assets",
        "Check scripts/minify-assets.ps1 completed successfully",
        "Verify .min files exist in public_html/resources/css/ and /js/",
        "Deploy to production with deploy.ps1 (includes build step)"
      ]
    }
  },
  "integration_points": {
    "bootstrap_theme": {
      "description": "How Bootstrap 5.3.8 theming works",
      "files": ["main.css (custom properties)", "custom.css (overrides)"],
      "dark_mode": "theme-toggle.js manages data-bs-theme attribute on <html>",
      "customization": "Use CSS custom properties in main.css (--bs-primary, --bs-body-bg, etc.)"
    },
    "tag_system": {
      "description": "How tag filtering integrates with assets",
      "css": ["tags-theme.css (badge colors, filter UI)"],
      "js": ["tag-system.js (filtering engine)", "tag-cloud.js (offcanvas UI)", "tag-filter-api.js (API)"],
      "dependencies": ["See .config/tag-deps.json for complete tag system architecture"]
    },
    "video_system": {
      "description": "How YouTube integration works with assets",
      "js": ["youtube-grid.js (RSS rendering)", "diy-playlists.js (DIY specialization)"],
      "cdn": ["js-yaml (YAML parsing)"],
      "proxy": ["get-youtube.php (RSS → JSON)"],
      "dependencies": ["See .config/video-deps.json for complete video system architecture"]
    }
  }
}
