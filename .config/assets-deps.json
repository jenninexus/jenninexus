          "res_root_definition": "Line 3: if (!defined('RES_ROOT')) define('RES_ROOT', '/resources');",
          "custom_css_injection": "Lines 164-169: Loops through $customCSS array if set by page",
          "window_variable": "Lines 157-159: Exposes window.RES_ROOT for JavaScript resource loading",
          "critical": true
