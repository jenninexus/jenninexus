          "environment_detection": "Lines 18-24: Checks $assetSuffix or re-detects environment",
          "res_root_definition": "Line 16: if (!defined('RES_ROOT')) define('RES_ROOT', '/resources');",
          "page_scripts_injection": "Lines 140-151: Loops through $pageScripts array, handles absolute URLs",
          "path_depth_detection": "Lines 4-13: Calculates $pathPrefix for nested pages (../)",
          "critical": true
        }
      ]
